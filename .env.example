APP_NAME="Book Reading App"
APP_ENV=local
APP_KEY=base64:defaultkeyfordevonlypleasechange=
APP_DEBUG=true
APP_URL=http://localhost:8080

# Database - MySQL via Docker
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=book_reading
DB_USERNAME=book_user
DB_PASSWORD=secret

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache & Session
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Other settings
BROADCAST_DRIVER=log
LOG_CHANNEL=stack

# Book system config
DEFAULT_FONT_SIZE=16
BASE_CHARS_PER_PAGE=2000
